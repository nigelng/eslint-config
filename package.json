{
  "name": "@nigelng/eslint-config",
  "version": "3.0.0",
  "description": "Shared ESLint configuration for Nigel Nguyen projects",
  "type": "module",
  "author": "Nigel Nguyen <nigel@nng.me>",
  "license": "MIT",
  "files": [
    "index.js",
    "typescript.js",
    "react.js",
    "security.js",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:nigelng/eslint-config.git"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./typescript": "./typescript.js",
    "./react": "./react.js",
    "./security": "./security.js"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.10.2",
    "@eslint/js": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.7.0"
  },
  "peerDependencies": {
    "eslint": "^10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "prettier": ">=3.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-no-unsanitized": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-regexp": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nigelng/prettier-config": "3.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "prettier": "3.8.3",
    "react": "^19.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
